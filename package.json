{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:xml": "node scripts/generate-xml.js",
    "build": "node scripts/generate-xml.js && vite build",
    "preview": "vite preview",
    "cf:deploy": "npm run build && npx wrangler pages deploy dist --project-name dogparentguide",
    "worker:deploy": "npx wrangler deploy",
    "db:seed": "npx wrangler d1 execute dpg-db --file=schema.sql --remote"
  },
  "dependencies": {
    "@types/react-router-dom": "^5.3.3",
    "clsx": "2.1.1",
    "date-fns": "^4.4.0",
    "fuse.js": "^7.4.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-helmet-async": "^3.0.0",
    "react-intersection-observer": "^10.0.3",
    "react-router-dom": "^7.18.0",
    "react-share": "^5.3.0",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vite-plugin-singlefile": "2.3.0"
  }
}
