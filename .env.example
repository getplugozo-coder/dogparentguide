# ============================================================
# DogParentGuide - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values

# Google Sheets CMS (Direct API)
VITE_GOOGLE_SHEETS_ID=your_spreadsheet_id_here
VITE_GOOGLE_SHEETS_API_KEY=your_api_key_here

# OR: Cloudflare Worker Proxy (Recommended)
VITE_CLOUDFLARE_WORKER_URL=https://your-worker.workers.dev

# Google Analytics
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
